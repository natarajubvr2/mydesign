        <script><![CDATA[(function runMailScript(current, template, email, email_action, event) {

    template.print("<table border='1'><tr><td>Task Number</td><td>Task Name</td><td>Assigned to</td><td>Issue Name</td></tr>");

    template.print("<tr><td><a href='/sn_grc_task.do?sys_id=" + current.sys_id + "'>" + current.number + "</td><td>" + current.short_description + "</td><td>" + current.assigned_to.getDisplayValue() + "</td><td>" + current.issue.getDisplayValue() + "</td></tr>");

    template.print("</table>");

})(current, template, email, email_action, event);]]></script>
